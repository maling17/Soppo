<resources xmlns:tools="http://schemas.android.com/tools">
    <!-- Base application theme. -->
    <style name="Theme.Soppo" parent="Theme.MaterialComponents.DayNight.NoActionBar">
        <!-- Primary brand color. -->
        <item name="colorPrimary">@color/orange</item>
        <item name="colorPrimaryVariant">@color/cream</item>
        <item name="colorOnPrimary">@color/white</item>
        <!-- Secondary brand color. -->
        <item name="colorSecondary">@color/orange</item>
        <item name="colorSecondaryVariant">@color/cream</item>
        <item name="colorOnSecondary">@color/white</item>
        <!-- Status bar color. -->
        <item name="android:statusBarColor" tools:targetApi="l">?attr/colorPrimary</item>
        <!-- Customize your theme here. -->
    </style>

    <style name="shapeButtonActive" parent="Widget.MaterialComponents.Button.OutlinedButton">
        <item name="shapeAppearance">@style/shapeRounded</item>
        <item name="backgroundTint">@color/orange_20</item>
        <item name="strokeColor">@color/orange</item>
    </style>
    <style name="shapeButtonInactive" parent="Widget.MaterialComponents.Button.OutlinedButton">
        <item name="shapeAppearance">@style/shapeRounded</item>
        <item name="backgroundTint">@color/white</item>
        <item name="strokeColor">@color/orange</item>
    </style>

    <style name="shapeRounded" parent="ShapeAppearance.MaterialComponents.MediumComponent">
        <item name="cornerFamily">rounded</item>
        <item name="cornerSize">20dp</item>
    </style>

